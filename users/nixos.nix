# =============================================================================
# NixOS 系统用户配置
# =============================================================================
# 此文件定义了用户级别的 NixOS 系统配置
# 主要用于 SSH 密钥管理等系统级用户设置
# =============================================================================

{ username, ... }:

{
  # ============================================================================
  # 用户配置
  # ============================================================================
  users.users.${username} = {
    # SSH 授权密钥
    # 用于无密码 SSH 登录
    # 注意：这些密钥存储在系统配置中，建议使用 NixOS 的 secrets 管理敏感信息
    openssh.authorizedKeys.keys = [
      # --------------------------------------------------------------------------
      # 示例 SSH 密钥（已注释）
      # --------------------------------------------------------------------------
      # 格式：ssh-ed25519 AAAAC3NzaC1lZDI1NTE5... user@hostname
      #
      # 要添加新的 SSH 密钥：
      # 1. 取消注释上面的行
      # 2. 将密钥内容替换为你的公钥
      # 3. 运行：sudo nixos-rebuild switch --flake .#nixos
      #
      # 获取你的公钥：
      #   cat ~/.ssh/id_ed25519.pub
      #   cat ~/.ssh/id_rsa.pub
      #
      # "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIJx3Sk20pLL1b2PPKZey2oTyioODrErq83xG78YpFBoj ryan@ryan"
    ];
  };
}
