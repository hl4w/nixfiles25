# =============================================================================
# Home Manager 用户配置入口
# =============================================================================
# 这是 Home Manager 的主入口文件，导入所有用户级配置模块
# =============================================================================

{pkgs, ...}:

{
  # ============================================================================
  # 配置说明
  # ============================================================================
  # 此配置文件定义了用户环境的所有设置，包括：
  # - 基础配置（Shell、Git 等）
  # - 应用程序配置（Fcitx5、Hyprland 等）
  # - 主题配置（Waybar、Rofi、Dunst 等）
  # - 开发工具配置（Neovim 等）
  # ============================================================================

  # ============================================================================
  # 模块导入
  # ============================================================================
  imports = [
    # --------------------------------------------------------------------------
    # 基础配置
    # --------------------------------------------------------------------------
    ../home/core.nix           # Home Manager 核心配置
    ../home/programs           # 用户软件包配置目录

    # --------------------------------------------------------------------------
    # 输入法
    # --------------------------------------------------------------------------
    ../home/fcitx5            # Fcitx5 中文输入法配置

    # --------------------------------------------------------------------------
    # Hyprland 桌面环境
    # --------------------------------------------------------------------------
    ../home/hypr              # Hyprland 配置和安装脚本
    ../home/waybar           # Waybar 状态栏配置
    ../home/rofi             # Rofi 启动器配置
    ../home/wlogout          # Wlogout 注销菜单配置
    ../home/swappy           # Swappy 截图标注工具配置
    ../home/wal              # PyWal 动态色彩配置

    # --------------------------------------------------------------------------
    # 主题和外观
    # --------------------------------------------------------------------------
    ../home/wallpapers        # 壁纸集合
    ../home/gtkqt            # GTK/Qt 主题配置
    ../home/dunst            # Dunst 通知守护进程配置

    # --------------------------------------------------------------------------
    # 开发工具
    # --------------------------------------------------------------------------
    ../home/nvim              # Neovim 配置

    # --------------------------------------------------------------------------
    # 脚本和工具
    # --------------------------------------------------------------------------
    ../home/scripts           # 脚本集合
    ../home/settings         # 用户设置（壁纸引擎、模糊程度等）

    # --------------------------------------------------------------------------
    # Shell 配置
    # --------------------------------------------------------------------------
    ../home/shell             # Shell 配置（Zsh 等）
  ];

  # ============================================================================
  # Git 配置
  # ============================================================================
  programs.git = {
    enable = true;  # 启用 Git

    settings = {
      # Git 用户信息
      user.name = "<your-name>";
      user.email = "<your-email>";
    };
  };
}
